rules_version = '2';

// Craft rules based on the exact path in your storage bucket
service firebase.storage {
  match /b/{bucket}/o {
    
    // As regras do VukaPay Backups
    match /backups/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regras de leitura pública para as atualizações automáticas (Tauri/Android)
    match /updates/{allPaths=**} {
      allow read: if true;
    }
    
    // Regras padrão de leitura para avatares públicos ou outros recursos, se necessário
    match /public/{allPaths=**} {
      allow read: if true;
    }
  }
}
