rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Função auxiliar: verifica se o utilizador autenticado é o Admin ───
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'nCSaiyU9GJbQvH3maeblHbccMXz2';
    }

    // ─── Coleção: licenses ───────────────────────────────────────────────────
    match /licenses/{licenseKey} {
      allow read, write: if isAdmin();
      allow get: if request.auth == null || !isAdmin();
      allow update: if
        (resource.data.hardware_id == null || resource.data.hardware_id == '') &&
        resource.data.status == 'active' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hardware_id']) &&
        request.resource.data.hardware_id is string &&
        request.resource.data.hardware_id.size() > 0;
    }

    // ─── Coleção: trials ─────────────────────────────────────────────────────
    match /trials/{hardwareId} {
      allow read, write: if isAdmin();
      allow get: if true;
      allow create: if
        request.resource.data.keys().hasAll(['hardware_id', 'started_at', 'expires_at']) &&
        request.resource.data.hardware_id is string &&
        request.resource.data.hardware_id.size() > 0;
      allow update, delete: if isAdmin();
    }

    // ─── Coleção: payment_proofs ─────────────────────────────────────────────
    match /payment_proofs/{proofId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Coleções da Comunidade VukaPay ──────────────────────────────────────
    match /community_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.authorId);
      
      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.authorId);
      }
    }
    match /community_stories/{storyId} {
      allow read, create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.authorId);
    }
    match /community_groups/{groupId} {
      allow read, create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.creatorId);
    }
    match /community_challenges/{challengeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /community_users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }
    match /community_chats/{chatId} {
      allow read, create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.senderId);
      
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.senderId);
      }
    }
    match /education_courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /education_fundamentals/{fundamentalId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Todas as outras coleções: bloqueadas para não-admins ────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
