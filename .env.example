# ─── Supabase (autenticação Google OAuth) ───────────────────────────────────
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Firebase (sistema de licenciamento VukaPay) ─────────────────────────────
# Obtenha no Firebase Console → Configurações do Projeto → Suas apps → Web
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Painel Admin ─────────────────────────────────────────────────────────────
# UID do utilizador administrador no Firebase Authentication
# Encontre em: Firebase Console → Authentication → Users → copie o UID
VITE_ADMIN_UID=your-firebase-admin-uid-here

# ─── Configurações do Trial e Licença ────────────────────────────────────────
# URL da página de compra de licença (ex: Gumroad, Stripe, site próprio)
VITE_LICENSE_PURCHASE_URL=https://vukapay.com/adquirir

# Chave secreta para HMAC da assinatura local (mín. 32 caracteres aleatórios)
# Gere em: https://generate-secret.now.sh/64
VITE_LICENSE_HMAC_SECRET=sua-chave-secreta-hmac-minimo-32-chars

# Emulador Firestore local (apenas desenvolvimento, deixe 'false' em produção)
VITE_USE_FIREBASE_EMULATOR=false
