{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VukaPay",
  "version": "1.1.5",
  "identifier": "com.vukapay.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VukaPay - Controle Financeiro Pessoal",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "licenseFile": "./windows/license.txt",
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "startMenuFolder": "VukaPay",
        "installerHooks": "./windows/hooks.nsh",
        "languages": ["Portuguese", "English"],
        "compression": "lzma",
        "installerIcon": "./icons/icon.ico",
        "headerImage": "./windows/installer-header.bmp",
        "sidebarImage": "./windows/installer-sidebar.bmp",
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyODBFQTQxMTYzMzFGOEYKUldTUEh6TVdRZXFBTW1jZ1NjaFdocE9maEhHUS9ITW5BVHN3cGpCd1JDZFhQejc4YUpYQU0yUWgK",
      "endpoints": [
        "https://raw.githubusercontent.com/marcosdc20/sistema-de-controle-financeiro-pessoal-financer/main/updater.json"
      ]
    }
  }
}
